# Database — Neon PostgreSQL (same project as Rumbo v1, DB: rumboapp)
DATABASE_URL=postgresql://user:pass@host/rumboapp?sslmode=require

# Auth — Better Auth (NEW secret, separate from Rumbo v1)
BETTER_AUTH_SECRET=generate-a-new-secret-here
BETTER_AUTH_URL=http://localhost:3001

# Email — Resend (reused from Rumbo v1)
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=RumboApp <noreply@dsmj.dev>

# App URLs
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001

# Vercel — disable Node.js helpers (required for Hono)
NODEJS_HELPERS=0

# AI — Vercel AI SDK (pick your provider)
OPENAI_API_KEY=sk-xxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# GOOGLE_GENERATIVE_AI_API_KEY=xxxxx
